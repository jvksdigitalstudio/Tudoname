<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Seleccionado: gradiente dorado como en la web -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFCA6E"
                android:endColor="#FF9F43"
                android:angle="135" />
            <corners android:radius="50dp" />
            <stroke android:width="1.5dp" android:color="#FFE8B0" />
        </shape>
    </item>
    <!-- Normal: glass blanco translúcido -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#8AFFFFFF" />
            <corners android:radius="50dp" />
            <stroke android:width="1.5dp" android:color="#BBFFFFFF" />
        </shape>
    </item>
</selector>
