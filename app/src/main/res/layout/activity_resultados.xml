<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootResultados"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Back button -->
    <ImageView
        android:id="@+id/btnVolver"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_back"
        android:padding="8dp"
        android:background="@drawable/btn_circle_bg"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tudoname"
        android:textSize="42sp"
        android:fontFamily="sans-serif-condensed"
        android:textColor="@color/gold_light"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="10"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tipo label -->
    <TextView
        android:id="@+id/tvTipo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:fontFamily="sans-serif-condensed"
        android:textColor="@color/orange_primary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Name Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardNombre"
        android:layout_width="0dp"
        android:layout_height="200dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="22dp"
        app:cardBackgroundColor="@color/card_bg"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvTipo"
        app:layout_constraintBottom_toTopOf="@id/navRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="52sp"
                android:fontFamily="sans-serif-condensed"
                android:textColor="@color/orange_primary"
                android:gravity="center"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/tvNumero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/step_label"
                android:letterSpacing="0.1"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Nav row: Anterior / 🎲 / Siguiente -->
    <LinearLayout
        android:id="@+id/navRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAnterior"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="◀  Anterior"
            android:textSize="15sp"
            android:fontFamily="sans-serif-condensed"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_secondary"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnRandom"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="🎲"
            android:textSize="22sp"
            android:background="@drawable/btn_circle"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSiguiente"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Siguiente  ▶"
            android:textSize="15sp"
            android:fontFamily="sans-serif-condensed"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_gradient"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
