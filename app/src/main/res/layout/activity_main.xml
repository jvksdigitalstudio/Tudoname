<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- FONDO completo -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fondo"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tudoname"
            android:textSize="52sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:textColor="#FFE566"
            android:shadowColor="#CC000000"
            android:shadowDx="2"
            android:shadowDy="4"
            android:shadowRadius="14"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TAGLINE -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra el nombre perfecto para bebés y mascotas"
            android:textSize="11sp"
            android:textColor="#EEFFFFFF"
            android:fontFamily="sans-serif"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            HOJA: tamaño basado en el cuadrado verde marcado por el usuario.
            360dp ancho x 310dp alto, posicionada en el 60% vertical
            (justo sobre los animales, debajo de los bebés)
        -->
        <FrameLayout
            android:id="@+id/cardContent"
            android:layout_width="360dp"
            android:layout_height="310dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.60">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hoja"
                android:scaleType="fitXY"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="18dp"
                android:paddingBottom="10dp"
                android:paddingHorizontal="18dp">

                <!-- "Seleccionar género" -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Seleccionar género ✨"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#CC5500"
                    android:layout_marginBottom="4dp" />

                <!-- Bebés -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶 Bebés"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/rgBebes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="6dp">

                    <RadioButton
                        android:id="@+id/rbNino"
                        style="@style/GeneroButton"
                        android:text="Niño"
                        android:layout_marginEnd="8dp" />

                    <RadioButton
                        android:id="@+id/rbNina"
                        style="@style/GeneroButton"
                        android:text="Niña" />

                </RadioGroup>

                <!-- Mascotas -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾 Mascotas"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/rgMascotas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="0dp">

                    <RadioButton
                        android:id="@+id/rbPerro"
                        style="@style/GeneroButton"
                        android:text="Perro"
                        android:layout_marginEnd="4dp" />

                    <RadioButton
                        android:id="@+id/rbPerra"
                        style="@style/GeneroButton"
                        android:text="Perra"
                        android:layout_marginEnd="4dp" />

                    <RadioButton
                        android:id="@+id/rbGato"
                        style="@style/GeneroButton"
                        android:text="Gato"
                        android:layout_marginEnd="4dp" />

                    <RadioButton
                        android:id="@+id/rbGata"
                        style="@style/GeneroButton"
                        android:text="Gata" />

                </RadioGroup>

                <!-- Botón Siguiente -->
                <Button
                    android:id="@+id/btnSiguiente"
                    android:layout_width="200dp"
                    android:layout_height="44dp"
                    android:text="➤  Siguiente"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_gradient"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="8dp" />

                <!-- Dots + PASO -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="7dp">

                    <View
                        android:layout_width="20dp"
                        android:layout_height="5dp"
                        android:background="@drawable/dot_active"
                        android:layout_marginEnd="4dp" />

                    <View
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:background="@drawable/dot_inactive" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASO 1 DE 2"
                    android:textSize="8sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="2dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- FOOTER -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miles de nombres de bebés y mascotas"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
