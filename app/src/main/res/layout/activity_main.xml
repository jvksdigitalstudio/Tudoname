<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- FONDO: imagen bebés y mascotas a pantalla completa -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fondo"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- CONTENIDO principal -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TÍTULO "Tudoname" arriba -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tudoname"
            android:textSize="52sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:textColor="#FFE566"
            android:shadowColor="#CC000000"
            android:shadowDx="2"
            android:shadowDy="4"
            android:shadowRadius="14"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TAGLINE debajo del título -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra el nombre perfecto para bebés y mascotas"
            android:textSize="11sp"
            android:textColor="#EEFFFFFF"
            android:fontFamily="sans-serif"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- HOJA: centrada verticalmente en la mitad superior-media de pantalla -->
        <FrameLayout
            android:id="@+id/cardContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvTagline"
            app:layout_constraintBottom_toTopOf="@id/tvFooter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.38">

            <!-- Imagen hoja como fondo exacto del contenido -->
            <ImageView
                android:id="@+id/imgHoja"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hoja"
                android:scaleType="fitXY"
                android:contentDescription="@null" />

            <!-- Contenido encima de la hoja -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="28dp"
                android:paddingBottom="20dp"
                android:paddingHorizontal="16dp">

                <!-- "Seleccionar género" -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Seleccionar género ✨"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#CC5500"
                    android:layout_marginBottom="8dp" />

                <!-- Bebés label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶 Bebés"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rgBebes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="10dp">

                    <RadioButton
                        android:id="@+id/rbNino"
                        style="@style/GeneroButton"
                        android:text="Niño"
                        android:layout_marginEnd="10dp" />

                    <RadioButton
                        android:id="@+id/rbNina"
                        style="@style/GeneroButton"
                        android:text="Niña" />

                </RadioGroup>

                <!-- Separador -->
                <View
                    android:layout_width="50dp"
                    android:layout_height="1dp"
                    android:background="#44CC8800"
                    android:layout_marginBottom="10dp" />

                <!-- Mascotas label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾 Mascotas"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rgMascotas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="4dp">

                    <RadioButton
                        android:id="@+id/rbPerro"
                        style="@style/GeneroButton"
                        android:text="Perro"
                        android:layout_marginEnd="5dp" />

                    <RadioButton
                        android:id="@+id/rbPerra"
                        style="@style/GeneroButton"
                        android:text="Perra"
                        android:layout_marginEnd="5dp" />

                    <RadioButton
                        android:id="@+id/rbGato"
                        style="@style/GeneroButton"
                        android:text="Gato"
                        android:layout_marginEnd="5dp" />

                    <RadioButton
                        android:id="@+id/rbGata"
                        style="@style/GeneroButton"
                        android:text="Gata" />

                </RadioGroup>

                <!-- Botón Siguiente — rosa/salmon igual que la web -->
                <Button
                    android:id="@+id/btnSiguiente"
                    android:layout_width="200dp"
                    android:layout_height="46dp"
                    android:text="➤  Siguiente"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_gradient"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="14dp" />

                <!-- Dots + paso -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="10dp">

                    <View
                        android:layout_width="22dp"
                        android:layout_height="6dp"
                        android:background="@drawable/dot_active"
                        android:layout_marginEnd="5dp" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/dot_inactive" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASO 1 DE 2"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="3dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- FOOTER -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miles de nombres de bebés y mascotas"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
