<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tudoname"
            android:textSize="64sp"
            android:textStyle="bold"
            android:fontFamily="@font/fredoka_one"
            android:textColor="@color/gold_light"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="12" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra el nombre perfecto para bebés y mascotas"
            android:textSize="13sp"
            android:textColor="#DDFFFFFF"
            android:fontFamily="sans-serif"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!-- ── CARD: Hoja con selección ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="18dp"
        app:cardBackgroundColor="@color/card_bg"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.44">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="32dp"
            android:paddingHorizontal="28dp">

            <!-- Título de sección -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Seleccionar género ✨"
                android:textSize="20sp"
                android:fontFamily="@font/fredoka_one"
                android:textColor="@color/orange_primary"
                android:letterSpacing="0.04"
                android:layout_marginBottom="20dp" />

            <!-- Bebés -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👶 Bebés"
                android:textSize="17sp"
                android:fontFamily="@font/fredoka_one"
                android:textColor="@color/blue_title"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgBebes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rbNino"
                    style="@style/GeneroButton"
                    android:text="Niño"
                    android:layout_marginEnd="10dp" />

                <RadioButton
                    android:id="@+id/rbNina"
                    style="@style/GeneroButton"
                    android:text="Niña" />

            </RadioGroup>

            <!-- Separador -->
            <View
                android:layout_width="60dp"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="20dp" />

            <!-- Mascotas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾 Mascotas"
                android:textSize="17sp"
                android:fontFamily="@font/fredoka_one"
                android:textColor="@color/blue_title"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgMascotas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <RadioButton
                    android:id="@+id/rbPerro"
                    style="@style/GeneroButton"
                    android:text="Perro"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rbPerra"
                    style="@style/GeneroButton"
                    android:text="Perra"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rbGato"
                    style="@style/GeneroButton"
                    android:text="Gato"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rbGata"
                    style="@style/GeneroButton"
                    android:text="Gata" />

            </RadioGroup>

            <!-- Botón Siguiente -->
            <Button
                android:id="@+id/btnSiguiente"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:text="➤  Siguiente"
                android:textSize="17sp"
                android:fontFamily="@font/fredoka_one"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.06"
                android:background="@drawable/btn_gradient"
                android:stateListAnimator="@null"
                android:layout_marginTop="24dp" />

            <!-- Progreso dots -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <View
                    android:layout_width="26dp"
                    android:layout_height="7dp"
                    android:background="@drawable/dot_active"
                    android:layout_marginEnd="6dp" />

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/dot_inactive" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paso 1 de 2"
                android:textSize="10sp"
                android:textColor="@color/step_label"
                android:letterSpacing="0.14"
                android:layout_marginTop="6dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── FOOTER ── -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Miles de nombres de bebés y mascotas"
        android:textSize="11sp"
        android:textColor="#AAFFFFFF"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
