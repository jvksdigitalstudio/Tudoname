<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo imagen -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fondo"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Overlay oscuro sutil como en la web -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#14003C50" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- HEADER: Logo Tudoname grande con shimmer -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tudoname"
            android:textSize="62sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:textColor="#FFE566"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="18"
            android:letterSpacing="0.05"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Línea decorativa superior (tagline-wrap::before) -->
        <View
            android:id="@+id/dividerTop"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@drawable/divider_line"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="60dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tagline itálico -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra el nombre perfecto para bebés y mascotas"
            android:textSize="13sp"
            android:textColor="#EEFFFFFF"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:shadowColor="#DD000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="8"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/dividerTop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Línea decorativa inferior (tagline-wrap::after) -->
        <View
            android:id="@+id/dividerBottom"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@drawable/divider_line"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="60dp"
            app:layout_constraintTop_toBottomOf="@id/tvTagline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- HOJA: contenedor centrado con imagen hoja de fondo -->
        <FrameLayout
            android:id="@+id/cardContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:elevation="12dp"
            app:layout_constraintWidth_percent="0.82"
            app:layout_constraintDimensionRatio="900:1008"
            app:layout_constraintTop_toBottomOf="@id/dividerBottom"
            app:layout_constraintBottom_toTopOf="@id/tvFooter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.5">

            <!-- Imagen hoja de fondo -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hoja"
                android:scaleType="fitXY"
                android:contentDescription="@null" />

            <!-- Contenido sobre la hoja -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="36dp"
                android:paddingBottom="18dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- ✨ Seleccionar género ✨ -->
                <TextView
                    android:id="@+id/tvSectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Seleccionar género ✨"
                    android:textSize="19sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#E05A00"
                    android:gravity="center"
                    android:shadowColor="#40FFFFFF"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- 👶 Bebés -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶 Bebés"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:gravity="center"
                    android:shadowColor="#33003C78"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3" />

                <Space android:layout_width="0dp" android:layout_height="4dp"/>

                <!-- Opciones bebés -->
                <RadioGroup
                    android:id="@+id/rgBebes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <RadioButton
                        android:id="@+id/rbNino"
                        style="@style/GeneroButton"
                        android:button="@null"
                        android:text="Niño"
                        android:layout_marginEnd="10dp" />
                    <RadioButton
                        android:id="@+id/rbNina"
                        style="@style/GeneroButton"
                        android:button="@null"
                        android:text="Niña" />
                </RadioGroup>

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Separador -->
                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:background="#44FFFFFF" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- 🐾 Mascotas -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾 Mascotas"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:gravity="center"
                    android:shadowColor="#33003C78"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3" />

                <Space android:layout_width="0dp" android:layout_height="4dp"/>

                <!-- Opciones mascotas en grid 4 -->
                <RadioGroup
                    android:id="@+id/rgMascotas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <RadioButton
                        android:id="@+id/rbPerro"
                        style="@style/GeneroButton"
                        android:button="@null"
                        android:text="Perro"
                        android:layout_marginEnd="6dp" />
                    <RadioButton
                        android:id="@+id/rbPerra"
                        style="@style/GeneroButton"
                        android:button="@null"
                        android:text="Perra"
                        android:layout_marginEnd="6dp" />
                    <RadioButton
                        android:id="@+id/rbGato"
                        style="@style/GeneroButton"
                        android:button="@null"
                        android:text="Gato"
                        android:layout_marginEnd="6dp" />
                    <RadioButton
                        android:id="@+id/rbGata"
                        style="@style/GeneroButton"
                        android:button="@null"
                        android:text="Gata" />
                </RadioGroup>

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Botón Siguiente -->
                <Button
                    android:id="@+id/btnSiguiente"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="➤  Siguiente"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_gradient"
                    android:stateListAnimator="@null"
                    android:shadowColor="#99FF8C00"
                    android:shadowDx="0"
                    android:shadowDy="4"
                    android:shadowRadius="12"
                    android:elevation="8dp" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Indicador de pasos -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <View
                        android:layout_width="26dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_active"
                        android:layout_marginEnd="6dp" />
                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_inactive" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASO 1 DE 2"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.15"
                    android:layout_marginTop="3dp" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            </LinearLayout>
        </FrameLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miles de nombres de bebés y mascotas"
            android:textSize="11sp"
            android:textColor="#AAD0FFFF"
            android:fontFamily="sans-serif"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_marginBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
