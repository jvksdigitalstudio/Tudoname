<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- FONDO completo -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fondo"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TÍTULO — Fredoka One, grande, con sombra dorada -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tudoname"
            android:textSize="68sp"
            android:fontFamily="@font/fredoka_one"
            android:textColor="#FFE566"
            android:shadowColor="#AA000000"
            android:shadowDx="0"
            android:shadowDy="5"
            android:shadowRadius="18"
            android:letterSpacing="0.04"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TAGLINE -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra el nombre perfecto para bebés y mascotas"
            android:textSize="11sp"
            android:textColor="#EEFFFFFF"
            android:fontFamily="sans-serif-light"
            android:textStyle="italic"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:layout_marginTop="1dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- HOJA: 70% ancho -->
        <FrameLayout
            android:id="@+id/cardContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:elevation="12dp"
            app:layout_constraintWidth_percent="0.70"
            app:layout_constraintDimensionRatio="900:1008"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.53">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hoja"
                android:scaleType="fitXY"
                android:contentDescription="@null" />

            <!-- LinearLayout con Space+weight para distribuir como justify-content:space-evenly -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="40dp"
                android:paddingBottom="22dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- ESPACIO top -->
                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- "Seleccionar género" — Fredoka One como en la web -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Seleccionar género ✨"
                    android:textSize="19sp"
                    android:fontFamily="@font/fredoka_one"
                    android:textColor="#CC5500"
                    android:gravity="center" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Bebés label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶 Bebés"
                    android:textSize="20sp"
                    android:fontFamily="@font/fredoka_one"
                    android:textColor="#0077BB"
                    android:gravity="center" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Bebés botones -->
                <RadioGroup
                    android:id="@+id/rgBebes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <RadioButton
                        android:id="@+id/rbNino"
                        style="@style/GeneroButton"
                        android:text="Niño"
                        android:layout_marginEnd="14dp" />

                    <RadioButton
                        android:id="@+id/rbNina"
                        style="@style/GeneroButton"
                        android:text="Niña" />

                </RadioGroup>

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Mascotas label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾 Mascotas"
                    android:textSize="20sp"
                    android:fontFamily="@font/fredoka_one"
                    android:textColor="#0077BB"
                    android:gravity="center" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Mascotas botones -->
                <RadioGroup
                    android:id="@+id/rgMascotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <RadioButton
                        android:id="@+id/rbPerro"
                        style="@style/GeneroButton"
                        android:text="Perro"
                        android:layout_marginEnd="7dp" />

                    <RadioButton
                        android:id="@+id/rbPerra"
                        style="@style/GeneroButton"
                        android:text="Perra"
                        android:layout_marginEnd="7dp" />

                    <RadioButton
                        android:id="@+id/rbGato"
                        style="@style/GeneroButton"
                        android:text="Gato"
                        android:layout_marginEnd="7dp" />

                    <RadioButton
                        android:id="@+id/rbGata"
                        style="@style/GeneroButton"
                        android:text="Gata" />

                </RadioGroup>

                <!-- Doble espacio antes del botón -->
                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="2"/>

                <!-- Botón Siguiente -->
                <Button
                    android:id="@+id/btnSiguiente"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="➤  Siguiente"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka_one"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_gradient"
                    android:stateListAnimator="@null" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Dots + PASO -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <View
                        android:layout_width="24dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_active"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_inactive" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASO 1 DE 2"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.15"
                    android:layout_marginTop="3dp" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            </LinearLayout>
        </FrameLayout>

        <!-- FOOTER -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miles de nombres de bebés y mascotas"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
