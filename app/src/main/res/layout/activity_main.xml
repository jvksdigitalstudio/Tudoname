<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── FONDO: imagen de bebés y mascotas ── -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fondo"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- ── OVERLAY oscuro suave para legibilidad del título ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#66000000" />

    <!-- ── CONTENIDO principal ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tudoname"
            android:textSize="58sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:textColor="#FFE566"
            android:shadowColor="#CC000000"
            android:shadowDx="2"
            android:shadowDy="4"
            android:shadowRadius="14"
            android:layout_marginTop="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TAGLINE -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra el nombre perfecto para bebés y mascotas"
            android:textSize="12sp"
            android:textColor="#EEFFFFFF"
            android:fontFamily="sans-serif"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- HOJA: imagen de la tarjeta con FrameLayout para superponer controles -->
        <FrameLayout
            android:id="@+id/cardContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTagline"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.52">

            <!-- Imagen de la hoja como fondo de la tarjeta -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hoja"
                android:scaleType="fitXY"
                android:contentDescription="@null" />

            <!-- Controles sobre la hoja -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="36dp"
                android:paddingBottom="28dp"
                android:paddingHorizontal="24dp">

                <!-- Título seleccionar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Seleccionar género ✨"
                    android:textSize="19sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#CC6600"
                    android:layout_marginBottom="16dp" />

                <!-- Bebés -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶 Bebés"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rgBebes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/rbNino"
                        style="@style/GeneroButton"
                        android:text="Niño"
                        android:layout_marginEnd="10dp" />

                    <RadioButton
                        android:id="@+id/rbNina"
                        style="@style/GeneroButton"
                        android:text="Niña" />

                </RadioGroup>

                <!-- Separador -->
                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:background="#44CC8800"
                    android:layout_marginBottom="16dp" />

                <!-- Mascotas -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾 Mascotas"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#0077BB"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rgMascotas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <RadioButton
                        android:id="@+id/rbPerro"
                        style="@style/GeneroButton"
                        android:text="Perro"
                        android:layout_marginEnd="6dp" />

                    <RadioButton
                        android:id="@+id/rbPerra"
                        style="@style/GeneroButton"
                        android:text="Perra"
                        android:layout_marginEnd="6dp" />

                    <RadioButton
                        android:id="@+id/rbGato"
                        style="@style/GeneroButton"
                        android:text="Gato"
                        android:layout_marginEnd="6dp" />

                    <RadioButton
                        android:id="@+id/rbGata"
                        style="@style/GeneroButton"
                        android:text="Gata" />

                </RadioGroup>

                <!-- Botón Siguiente -->
                <Button
                    android:id="@+id/btnSiguiente"
                    android:layout_width="210dp"
                    android:layout_height="50dp"
                    android:text="➤  Siguiente"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.06"
                    android:background="@drawable/btn_gradient"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="20dp" />

                <!-- Dots progreso -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="14dp">

                    <View
                        android:layout_width="26dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_active"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_inactive" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASO 1 DE 2"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.14"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- FOOTER -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miles de nombres de bebés y mascotas"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
